{
  "name": "mobile",
  "version": "1.2.1",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:staging": "set APP_VARIANT=staging&& set EXPO_PUBLIC_API_URL=https://appel-backend-staging.onrender.com/api&& expo start --clear",
    "start:prod": "set APP_VARIANT=production&& set EXPO_PUBLIC_API_URL=https://appel-q97a.onrender.com/api&& expo start --clear",
    "android": "expo run:android",
    "android:staging": "set APP_VARIANT=staging&& set EXPO_PUBLIC_API_URL=https://appel-backend-staging.onrender.com/api&& expo run:android",
    "android:prod": "set APP_VARIANT=production&& set EXPO_PUBLIC_API_URL=https://appel-q97a.onrender.com/api&& expo run:android",
    "build:local:eas:prod": "set APP_VARIANT=production&& set EXPO_PUBLIC_API_URL=https://appel-q97a.onrender.com/api&& npx eas build --platform android --profile production --local",
    "build:local:aab:prod": "set APP_VARIANT=production&& set EXPO_PUBLIC_API_URL=https://appel-q97a.onrender.com/api&& cd android&& gradlew.bat :app:bundleProductionRelease",
    "ios": "expo run:ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "~11.4.1",
    "@react-navigation/bottom-tabs": "^7.8.4",
    "@react-navigation/native": "^7.1.19",
    "@react-navigation/native-stack": "^7.6.2",
    "axios": "^1.13.2",
    "expo": "~54.0.35",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-location": "~19.0.8",
    "expo-print": "~15.0.8",
    "expo-screen-orientation": "~9.0.9",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-image-zoom-viewer": "^3.0.1",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.5",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-signature-canvas": "^5.0.2",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "socket.io-client": "^4.8.1"
  },
  "private": true
}
